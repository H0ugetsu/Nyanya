{
  "manifest_version": 3,
  "name": "Nyanya",
  "version": "0.0.1",
  "description": "🐱 Nyanya Pomodoro Timer",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "permissions": ["alarms", "storage", "offscreen", "notifications"]
}
